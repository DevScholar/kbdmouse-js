{
  "name": "@devscholar/kbdmouse-js",
  "description": "A JS polyfill that provides mouse and keyboard events support for mobile devices.",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "author": "DevScholar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devscholar/kbdmouse-js.git"
  },
  "bugs": {
    "url": "https://github.com/devscholar/kbdmouse-js/issues"
  },
  "homepage": "https://github.com/devscholar/kbdmouse-js#readme",
  "keywords": [
    "keyboard",
    "mouse",
    "touch",
    "mobile",
    "polyfill",
    "virtual-keyboard",
    "x86",
    "emulator",
    "retro"
  ],
  "main": "dist/kbdmouse-js.umd.js",
  "module": "dist/kbdmouse-js.es.js",
  "types": "dist/kbdmouse-js.es.d.ts",
  "exports": {
    ".": {
      "types": "./dist/kbdmouse-js.es.d.ts",
      "import": "./dist/kbdmouse-js.es.js",
      "require": "./dist/kbdmouse-js.umd.js"
    },
    "./dist/kbdmouse-js.css": "./dist/kbdmouse-js.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:expose": "vite --host",
    "build": "tsc && vite build --mode library",
    "build:lib": "tsc && vite build --mode library",
    "build:noPackaging": "tsc && vite build --mode noPackaging",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-html": "^3.2.2"
  }
}
